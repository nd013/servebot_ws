<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="servebot">

<!-- sim_mode arg — passed down to servebot_ros2_control.xacro -->
<xacro:arg name="sim_mode" default="true"/>

<!-- Include Gazebo Parameters -->
<xacro:include filename="$(find servebot_description)/urdf/servebot_gazebo.xacro" />

<!-- Include ros2_control Plugins -->
<xacro:include filename="$(find servebot_description)/urdf/servebot_ros2_control.xacro" />


<!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0.037" rpy="0 0 0"/>
  </joint>

  <!-- BASE LINK -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.09596" rpy="0 0 0"/>
      <mass value="5.132"/>
      <inertia ixx="0.1158"  ixy="0.0"  ixz="0.0"
                             iyy="0.1275" iyz="0.0"
                                          izz="0.2417"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- RIGHT WHEEL -->
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right"/>
    <origin xyz="0 -0.2225 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_right">
    <inertial>
      <origin xyz="0.0 -0.24238 0.060" rpy="0 0 0"/>
      <mass value="0.3177"/>
      <inertia ixx="0.0003084"  ixy="0.0"  ixz="0.0"
                                iyy="0.0005682" iyz="0.0"
                                                izz="0.0003084"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="3.14 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="3.14 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/wheel_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- LEFT WHEEL -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left"/>
    <origin xyz="0 0.2225 0.023" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_left">
    <inertial>
      <origin xyz="0.0 0.24238 0.060" rpy="0 0 0"/>
      <mass value="0.3177"/>
      <inertia ixx="0.0003084"  ixy="0.0"  ixz="0.0"
                                iyy="0.0005682" iyz="0.0"
                                                izz="0.0003084"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
       <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/wheel_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- CASTER FRONT RIGHT -->
  <joint name="caster_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_front_right"/>
    <origin xyz="0.1975 -0.1625 0.04" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_right">
    <inertial>
      <origin xyz="0.1975 -0.1625 0.04137" rpy="0 0 0"/>
      <mass value="0.1273"/>
      <inertia ixx="0.00007014"  ixy="0.0"  ixz="0.0"
                                 iyy="0.00007014" iyz="0.0"
                                                  izz="0.00003102"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_front_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_front_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- CASTER FRONT LEFT -->
  <joint name="caster_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_front_left"/>
    <origin xyz="0.1975 0.1625 0.04" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_left">
    <inertial>
      <origin xyz="0.1975 0.1625 0.04137" rpy="0 0 0"/>
      <mass value="0.1273"/>
      <inertia ixx="0.00007014"  ixy="0.0"  ixz="0.0"
                                 iyy="0.00007014" iyz="0.0"
                                                  izz="0.00003102"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_front_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_front_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- CASTER REAR RIGHT -->
  <joint name="caster_rear_right_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_rear_right"/>
    <origin xyz="-0.1975 -0.1625 0.04" rpy="0 0 0"/>
  </joint>

  <link name="caster_rear_right">
    <inertial>
      <origin xyz="-0.1975 -0.1625 0.04137" rpy="0 0 0"/>
      <mass value="0.1273"/>
      <inertia ixx="0.00007014"  ixy="0.0"  ixz="0.0"
                                 iyy="0.00007014" iyz="0.0"
                                                  izz="0.00003102"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_rear_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_rear_right.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- CASTER REAR LEFT -->
  <joint name="caster_rear_left_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_rear_left"/>
    <origin xyz="-0.1975 0.1625 0.04" rpy="0 0 0"/>
  </joint>

  <link name="caster_rear_left">
    <inertial>
      <origin xyz="-0.1975 0.1625 0.04137" rpy="0 0 0"/>
      <mass value="0.1273"/>
      <inertia ixx="0.00007014"  ixy="0.0"  ixz="0.0"
                                 iyy="0.00007014" iyz="0.0"
                                                  izz="0.00003102"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_rear_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="light_gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="-1.57 0 0"/>
      <geometry>
        <mesh filename="package://servebot_description/meshes/caster_rear_left.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="imu_link">
    <inertial>
      <origin xyz="-0.00552433659106688 0.000168210391520346 0.000514000497342681" rpy="0 0 0" />
      <mass value="0.000528415362211671" />
      <inertia ixx="1.46176048428261E-08" ixy="1.40015117949421E-10" ixz="-1.99633872937403E-12"
               iyy="8.59662482954888E-09" iyz="7.52375112767959E-12"
               izz="2.30279421279312E-08" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://servebot_description/meshes/imu_link.STL" />
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://servebot_description/meshes/imu_link.STL" />
      </geometry>
    </collision>
  </link>
  
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.119" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
    <axis xyz="0 0 0" />
  </joint>



</robot>